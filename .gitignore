# Root Git Ignore for Kavach Workshop Project

# Ignore Node Modules everywhere
node_modules/
**/node_modules/
smart-workshop/node_modules/
backend/node_modules/

# Ignore Build Dist Directories
dist/
**/dist/
dist-ssr/

# Ignore Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*

# Ignore Environment Files
.env
.env.local
.env.*.local

# Ignore Editor & OS Files
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# Ignore Temp & Database runtime files
*.sqlite-journal
